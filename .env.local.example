# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Direct postgres URL for running migrations (npm run db:migrate)
# Get from: Supabase Dashboard > Settings > Database > Connection string
SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.your-project.supabase.co:5432/postgres

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Get your API key at: https://resend.com/api-keys
RESEND_API_KEY=re_your_key
# The "from" address for transactional emails. Must be a verified domain in Resend.
RESEND_FROM_EMAIL=MyMatSH <noreply@yourdomain.com>

# ── SMS (Twilio) ──────────────────────────────────────────────────────────────
# Get credentials at: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxx
TWILIO_AUTH_TOKEN=your_token
# Must be a Twilio-provisioned number in E.164 format (e.g. +15551234567)
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── AI Parse (Anthropic Claude) ───────────────────────────────────────────────
# IMPORTANT: This key is from console.anthropic.com — it is a SEPARATE pay-per-use
# developer account from the Claude.ai consumer subscription at claude.ai.
# You must create an Anthropic account at console.anthropic.com and add billing
# before the key will work. Usage is billed per token.
ANTHROPIC_API_KEY=sk-ant-api03-your_key

# Claude model to use for parsing notes.
# Current recommended: claude-sonnet-4-5 (see https://docs.anthropic.com/en/docs/about-claude/models)
# See all models: https://docs.anthropic.com/en/docs/about-claude/models
AI_PARSE_MODEL=claude-sonnet-4-5

# Max output tokens per API call. Higher = bigger batches can complete.
# Default 4000 is sufficient for batches of 10 notes.
AI_PARSE_MAX_TOKENS=4000

# How many notes to include in each API call (batch size).
# Smaller = faster feedback but more API calls and cost overhead.
AI_PARSE_BATCH_SIZE=10

# How many batches to fire simultaneously before waiting.
# Higher = faster overall, but risks hitting Anthropic rate limits.
AI_PARSE_PARALLEL_BATCHES=3

# Milliseconds to wait between groups of parallel batches.
# Increase if you see 429 rate-limit errors from Anthropic.
AI_PARSE_DELAY_MS=200

# Token cost for estimated cost display on the review page.
# Update these if Anthropic changes pricing.
# Current pricing: https://www.anthropic.com/pricing
AI_COST_PER_MILLION_INPUT_TOKENS=3.00
AI_COST_PER_MILLION_OUTPUT_TOKENS=15.00

# ── AI Resume Parsing (Anthropic Claude) ─────────────────────────────────────
# Claude model for single-resume parsing (upload + AI parse on profile page).
# Defaults to AI_PARSE_MODEL if not set. Sonnet is recommended for accuracy.
AI_RESUME_MODEL=claude-sonnet-4-5

# Max output tokens per resume parse call.
# 2000 is plenty — a single resume produces far less JSON than a batch of notes.
AI_RESUME_MAX_TOKENS=2000

# ── AI Help Chat (Anthropic Claude) ──────────────────────────────────────────
# Model for the floating help chatbot.
AI_CHAT_MODEL=claude-sonnet-4-5

# Max tokens per chat response. 500 is plenty for 2-4 sentence answers.
AI_CHAT_MAX_TOKENS=500

# Max conversation turns (messages) to include in each API call.
# Older messages beyond this limit are dropped to keep costs low.
AI_CHAT_MAX_HISTORY=10

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Max AI chat requests per user per hour.
RATE_LIMIT_CHAT_PER_HOUR=50

# Max resume parse requests per user per day.
RATE_LIMIT_RESUME_PER_DAY=10

# Max Evernote batch parse requests per user per day.
# Note: the evernote-batch route is admin-only and has no rate limit applied;
# this value is kept here for reference if you re-enable it.
RATE_LIMIT_EVERNOTE_PER_DAY=20

# Comma-separated list of user roles that bypass per-route rate limits.
# Applied to routes that opt in via skipForRoles (currently: parse-resume).
# Chat/help always enforces limits regardless of this setting.
RATE_LIMIT_SKIP_ROLES=platform_admin
